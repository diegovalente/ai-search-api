# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# =============================================================================
# LLM Provider Selection
# =============================================================================
# Options: 'local', 'groq', 'mock'
# - local: Use Ollama, vLLM, or other local OpenAI-compatible server
# - groq: Use Groq cloud API (fast, free tier available)
# - mock: Use mock provider for testing (no LLM required)
LLM_PROVIDER=local

# =============================================================================
# Local LLM Provider (Ollama, vLLM, llama.cpp)
# =============================================================================
# Only used when LLM_PROVIDER=local
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434
LOCAL_LLM_MODEL=qwen2.5:7b
LOCAL_LLM_API_KEY=not-needed

# =============================================================================
# Groq Provider (https://console.groq.com)
# =============================================================================
# Only used when LLM_PROVIDER=groq
# Get your free API key at: https://console.groq.com/keys
GROQ_API_KEY=
# Available models:
# - llama-3.3-70b-versatile (best quality, recommended)
# - llama-3.1-8b-instant (faster, good quality)
# - mixtral-8x7b-32768 (good for complex tasks)
# - gemma2-9b-it (lightweight)
GROQ_MODEL=llama-3.3-70b-versatile

# =============================================================================
# Shared LLM Settings
# =============================================================================
LLM_TIMEOUT_MS=30000
LLM_MAX_TOKENS=256
LLM_TEMPERATURE=0.1

# =============================================================================
# Debug/Logging Controls
# =============================================================================
ENABLE_DEBUG_RAW_MODEL_OUTPUT=false
ENABLE_PROMPT_LOGGING=false
ALLOW_USER_TEXT_LOGGING=false

